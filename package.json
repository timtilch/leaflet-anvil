{
  "name": "leaflet-anvil",
  "version": "0.2.1",
  "description": "A minimal drawing and editing toolkit for Leaflet.",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite example",
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "leaflet",
    "draw",
    "edit",
    "map",
    "geometry"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/timtilch/leaflet-anvil"
  },
  "license": "MIT",
  "dependencies": {
    "@turf/turf": "^7.3.4"
  }
}
